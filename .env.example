# =============================================
# AEGIS C2 - Environment Variables Template
# =============================================
# Copy this file to .env and fill in actual values:
#   cp .env.example .env

# Database
DB_HOST=<DB_HOST>
DB_USER=<DB_USER>
DB_PASS=<DB_PASS>
DB_NAME=<DB_NAME>

# Redis
REDIS_HOST=<REDIS_HOST>
REDIS_PORT=<REDIS_PORT>

# JWT authentication
JWT_SECRET=<JWT_SECRET_MIN_64_CHARS>
JWT_ISSUER=<JWT_ISSUER>
JWT_AUDIENCE=<JWT_AUDIENCE>

# Operator credentials
AUTH_USERNAME=<AUTH_USERNAME>
AUTH_PASSWORD=<AUTH_PASSWORD>

# Optional GKS key passphrase
GKS_KEY_PASSPHRASE=<OPTIONAL_GKS_KEY_PASSPHRASE>

# Docker mode (API dynamic container spawn)
# HOST_KEYS_PATH must be an absolute host path to the local keys directory.
# Example: /home/user/projects/aegis-c2/keys
HOST_KEYS_PATH=<ABSOLUTE_KEYS_PATH>
